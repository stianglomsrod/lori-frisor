# Kopier til .env for lokal utvikling (aldri commit .env).
#
# Reservasjonsskjema (produkter) – e-post via Brevo:
#   BREVO_API_KEY   = API-nøkkel fra brevo.com (uten denne vises SMS-lenker)
#   BREVO_SENDER    = verifisert avsenderadresse i Brevo
#   RESERVATION_TO  = overstyr mottaker (standard: e-post fra Keystatic)
#
# Kun for lokal forhåndsvisning av skjema-dialogen uten Brevo-konto:
#   RESERVE_FORM_PREVIEW=1
BREVO_API_KEY=
BREVO_SENDER=nettside@lorifrisor.no
RESERVATION_TO=
RESERVE_FORM_PREVIEW=
