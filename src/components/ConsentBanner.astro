---
/**
 * Nøkternt samtykkebanner i stilen norske brukere kjenner, utformet etter
 * Datatilsynets krav til gyldig samtykke:
 *  - aktivt valg (ingen forhåndsavkryssing, ingen «aksept ved scrolling»)
 *  - like lett å avslå som å godta (to likeverdige knapper, ett klikk hver)
 *  - lett å trekke tilbake («Administrer informasjonskapsler» i footer
 *    åpner banneret igjen)
 *
 * Siden har bare ÉN ikke-nødvendig tredjepart: kartet fra Google Maps.
 * Ingen tredjeparts-scripts lastes før samtykke – kartet holdes igjen av
 * Contact-komponenten til valget er gjort (eller «Vis kart» klikkes der).
 *
 * Valget lagres i localStorage («lori-consent-v1» – selve lagringen er
 * strengt nødvendig og krever ikke samtykke). Endringer kringkastes som
 * CustomEvent «lori:consent» slik at kartet kan lastes/fjernes umiddelbart.
 */
import { resolveLocale, localePrivacy } from "@i18n/config";
import { useTranslations } from "@i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const t = useTranslations(locale);
const privacyHref = localePrivacy[locale];
---

<section
  class="consent"
  id="consent-banner"
  aria-label={t.consent.heading}
  hidden
  data-consent-banner
>
  <div class="consent__card">
    <h2 class="consent__heading">{t.consent.heading}</h2>
    <p class="consent__body">
      {t.consent.body}
      <a href={privacyHref}>{t.consent.readMore}</a>
    </p>
    <div class="consent__actions">
      <button class="btn btn--primary consent__btn" type="button" data-consent-accept>
        {t.consent.acceptAll}
      </button>
      <button class="btn btn--secondary consent__btn" type="button" data-consent-decline>
        {t.consent.essentialOnly}
      </button>
    </div>
  </div>
</section>

<style>
  .consent {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 60;
    padding: 0 var(--gutter) calc(1rem + env(safe-area-inset-bottom, 0px));
    pointer-events: none;
  }
  .consent__card {
    pointer-events: auto;
    max-width: 44rem;
    margin-inline: auto;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 1.25rem 1.5rem;
  }
  .consent__heading {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin: 0 0 0.5rem;
  }
  .consent__body {
    font-size: 0.98rem;
    color: var(--color-ink);
    margin: 0 0 1rem;
    max-width: none;
  }
  .consent__body a {
    color: var(--color-accent-dark);
    font-weight: 600;
  }
  .consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .consent__btn {
    min-height: 2.75rem;
    padding: 0.55rem 1.25rem;
    font-size: 0.95rem;
  }
  @media (max-width: 30rem) {
    .consent__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  import {
    CONSENT_KEY,
    readStoredConsent,
    type StoredConsent,
  } from "@lib/consent-client";

  const banner = document.querySelector<HTMLElement>("[data-consent-banner]");

  const writeConsent = (embeds: boolean) => {
    try {
      const value: StoredConsent = { v: 1, embeds, ts: new Date().toISOString() };
      localStorage.setItem(CONSENT_KEY, JSON.stringify(value));
    } catch {
      /* Privat modus uten lagring: valget gjelder da kun denne visningen. */
    }
    document.dispatchEvent(
      new CustomEvent("lori:consent", { detail: { embeds } }),
    );
  };

  const show = (focus = false) => {
    if (!banner) return;
    banner.hidden = false;
    if (focus) {
      banner.querySelector<HTMLButtonElement>("[data-consent-accept]")?.focus();
    }
  };
  const hide = () => {
    if (banner) banner.hidden = true;
  };

  if (banner) {
    banner
      .querySelector("[data-consent-accept]")
      ?.addEventListener("click", () => {
        writeConsent(true);
        hide();
      });
    banner
      .querySelector("[data-consent-decline]")
      ?.addEventListener("click", () => {
        writeConsent(false);
        hide();
      });

    // Første besøk (ingen lagret avgjørelse): vis banneret.
    if (readStoredConsent() === null) show();

    // «Administrer informasjonskapsler» i footer åpner banneret igjen.
    document.querySelectorAll("[data-open-consent]").forEach((el) =>
      el.addEventListener("click", (e) => {
        e.preventDefault();
        show(true);
      }),
    );

    // Kontekstuelt samtykke (f.eks. «Vis kart»-knappen i kontaktseksjonen):
    // én skriver – banneret tar imot forespørselen, lagrer og kringkaster.
    document.addEventListener("lori:consent-request", (e) => {
      const embeds = Boolean((e as CustomEvent).detail?.embeds);
      writeConsent(embeds);
      hide();
    });
  }
</script>
