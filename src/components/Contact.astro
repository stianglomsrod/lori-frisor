---
import { getSettings, getOpeningHours } from "@lib/content";

const { contact, booking, social } = await getSettings();
const openingHours = await getOpeningHours();

// Interaktivt kart bygget fra adressefeltene – endrer eier adressen i
// `site.ts`, oppdaterer kartet seg automatisk (ingen API-nøkkel nødvendig).
const mapQuery = encodeURIComponent(
  `${contact.addressStreet}, ${contact.addressZip} ${contact.addressCity}`
);
const mapEmbedUrl = `https://maps.google.com/maps?q=${mapQuery}&z=15&hl=no&output=embed`;
// Deep-link til veibeskrivelse – åpner kart-appen direkte på mobil.
const mapDirectionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${mapQuery}`;
---

<section class="section section--sand" id="kontakt" aria-labelledby="kontakt-tittel">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Kontakt</p>
      <h2 id="kontakt-tittel">Finn oss i Halden</h2>
      <p>Sentralt på Torget. Stikk innom, ring, eller bestill time på nett.</p>
    </div>

    <div class="contact reveal">
      <div class="contact__card card">
        <h3>Besøk &amp; kontakt</h3>
        <address class="contact__address">
          <p>
            <span class="contact__label">Adresse</span>
            <a href={contact.mapsUrl} target="_blank" rel="noopener">
              {contact.addressStreet}, {contact.addressZip} {contact.addressCity}
            </a>
          </p>
          <p>
            <span class="contact__label">Telefon</span>
            <a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>
          </p>
          <p>
            <span class="contact__label">E-post</span>
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </p>
        </address>

        <div class="contact__social">
          <a href={social.facebook} target="_blank" rel="noopener">Facebook</a>
          <a href={social.instagram} target="_blank" rel="noopener">Instagram</a>
        </div>

        <a class="btn btn--primary contact__cta" href={booking.url} target="_blank" rel="noopener">
          {booking.label}
        </a>
      </div>

      <div class="contact__card card">
        <h3>Åpningstider</h3>
        <table class="hours">
          <caption class="visually-hidden">Åpningstider per dag</caption>
          <tbody>
            {
              openingHours.map((d) => (
                <tr class={"closed" in d && d.closed ? "hours__closed" : ""}>
                  <th scope="row">{d.day}</th>
                  <td>{d.hours}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="contact__note">
          Avbestilling må skje senest 24 timer før timen.
        </p>
      </div>

      <div class="contact__map">
        <iframe
          title={`Kart som viser ${contact.addressStreet}, ${contact.addressZip} ${contact.addressCity}`}
          src={mapEmbedUrl}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <p class="contact__directions">
        <a class="btn btn--secondary" href={mapDirectionsUrl} target="_blank" rel="noopener">
          Få veibeskrivelse
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    gap: 1.25rem;
  }
  .contact__card {
    padding: clamp(1.5rem, 4vw, 2rem);
  }
  .contact__card h3 {
    margin-bottom: 1.25rem;
  }
  .contact__address {
    font-style: normal;
    display: grid;
    gap: 1rem;
  }
  .contact__address p {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .contact__label {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin-bottom: 0.15rem;
  }
  .contact__address a {
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
  }
  .contact__address a:hover {
    color: var(--color-accent-dark);
    text-decoration: underline;
  }
  .contact__social {
    display: flex;
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .contact__social a {
    font-weight: 600;
  }
  .contact__cta {
    width: 100%;
  }

  .hours {
    width: 100%;
    border-collapse: collapse;
  }
  .hours th,
  .hours td {
    text-align: left;
    padding: 0.7rem 0.25rem;
    border-bottom: 1px solid var(--color-line);
  }
  .hours th {
    font-weight: 500;
  }
  .hours td {
    text-align: right;
    font-weight: 600;
  }
  .hours__closed {
    color: var(--color-ink-soft);
  }
  .hours__closed td {
    font-weight: 500;
  }
  .contact__note {
    margin: 1.25rem 0 0;
    font-size: 0.92rem;
    color: var(--color-ink-soft);
  }
  .contact__map {
    grid-column: 1 / -1;
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-sand-deep);
  }
  .contact__map iframe {
    width: 100%;
    height: 260px;
    border: 0;
    display: block;
  }
  .contact__directions {
    grid-column: 1 / -1;
    max-width: none;
    margin: 0;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 48rem) {
    .contact {
      grid-template-columns: 1fr 1fr;
    }
    .contact__map iframe {
      height: 360px;
    }
  }
</style>
