---
import { getServices, getSettings } from "@lib/content";
import { resolveLocale } from "@i18n/config";
import { useTranslations } from "@i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const t = useTranslations(locale);
const services = await getServices(locale);
const { booking, contact } = await getSettings();

const priced = services.filter((s) => s.priceFrom !== null);
const onRequest = services.filter((s) => s.priceFrom === null);
---

<section class="section section--sand" id="priser" aria-labelledby="priser-tittel">
  <div class="container pricing">
    <div class="section-head reveal">
      <p class="eyebrow">{t.pricing.eyebrow}</p>
      <h2 id="priser-tittel">{t.pricing.title}</h2>
      <p>{t.pricing.intro}</p>
    </div>

    <div class="pricing__card card reveal">
      <table class="price-table">
        <caption class="visually-hidden">{t.pricing.caption}</caption>
        <thead>
          <tr>
            <th scope="col">{t.pricing.colService}</th>
            <th scope="col" class="price-table__num">{t.pricing.colFrom}</th>
          </tr>
        </thead>
        <tbody>
          {
            priced.map((s) => (
              <tr>
                <th scope="row">{s.title}</th>
                <td class="price-table__num">{t.pricing.price(s.priceFrom ?? 0)}</td>
              </tr>
            ))
          }
          {
            onRequest.map((s) => (
              <tr>
                <th scope="row">{s.title}</th>
                <td class="price-table__num price-table__req">{t.pricing.onRequest}</td>
              </tr>
            ))
          }
        </tbody>
      </table>

      <p class="pricing__note">
        <strong>{t.pricing.noteStrong}</strong> {t.pricing.noteBefore}
        <a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a> {t.pricing.noteOr}
        <a href="#kontakt">{t.pricing.noteContact}</a>{t.pricing.noteAfter}
      </p>
      <div class="pricing__actions">
        <a class="btn btn--primary" href={booking.url} target="_blank" rel="noopener">
          {t.cta.book}
        </a>
        <a class="btn btn--secondary" href={`tel:${contact.phone}`}>
          {t.pricing.callUs}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing__card {
    padding: clamp(1.25rem, 4vw, 2rem);
  }
  .price-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 1.05rem;
  }
  .price-table caption {
    text-align: left;
  }
  .price-table th,
  .price-table td {
    text-align: left;
    padding: 0.85rem 0.25rem;
    border-bottom: 1px solid var(--color-line);
  }
  .price-table thead th {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    font-weight: 700;
  }
  .price-table tbody th {
    font-weight: 600;
  }
  .price-table__num {
    text-align: right;
    white-space: nowrap;
  }
  .price-table__req {
    color: var(--color-ink-soft);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .pricing__note {
    margin: 1.5rem 0 1.25rem;
    color: var(--color-ink-soft);
  }
  .pricing__note a {
    color: var(--color-accent-dark);
    font-weight: 600;
  }
  .pricing__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
