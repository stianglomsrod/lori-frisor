---
import Placeholder from "./Placeholder.astro";
import { getProducts, getSettings, getOpeningHours } from "@lib/content";
import { resolveLocale, localePrivacy } from "@i18n/config";
import { useTranslations } from "@i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const t = useTranslations(locale);
const products = await getProducts(locale);
const { contact } = await getSettings();
const openingHours = await getOpeningHours();

// Lett variant av click-and-collect: kunden reserverer og henter i salong.
// To nivåer, ingen database og ingen nettbetaling:
//  1) Uten e-postoppsett (BREVO_API_KEY mangler): «Reserver» er en
//     forhåndsutfylt SMS-lenke – dagens robuste standard.
//  2) Med e-postoppsett: et lite skjema (dialog) sender reservasjonen som
//     e-post til salongen via /api/reserve. SMS forblir reserveløsning hvis
//     sendingen feiler eller JavaScript er av.
const reserveHref = (name: string) =>
  `sms:${contact.phone}?body=${encodeURIComponent(t.products.smsBody(name))}`;

const formEnabled = Boolean(
  import.meta.env.BREVO_API_KEY || import.meta.env.RESERVE_FORM_PREVIEW,
);
const pickupDays = openingHours.filter((d) => !d.closed).map((d) => d.day);
const privacyHref = localePrivacy[locale];
---

<section class="section section--sand" id="produkter" aria-labelledby="produkter-tittel">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{t.products.eyebrow}</p>
      <h2 id="produkter-tittel">{t.products.title}</h2>
      <p>{t.products.intro}</p>
    </div>

    <ul class="product-grid reveal" role="list">
      {
        products.map((product) => (
          <li class="product-card card">
            <div class="product-card__media">
              <Placeholder
                src={product.image || undefined}
                variant="product"
                ratio="1 / 1"
                fit="cover"
                label={t.common.placeholder}
                sizes="(min-width: 64rem) 30vw, (min-width: 40rem) 45vw, 92vw"
              />
              {product.featured && (
                <span class="product-card__badge">{t.products.recommended}</span>
              )}
            </div>
            <div class="product-card__body">
              <span class="product-card__cat">{product.category}</span>
              <h3>{product.name}</h3>
              <p class="product-card__brand">{product.brand}</p>
              <p class="product-card__desc">{product.description}</p>
              <div class="product-card__foot">
                <span class="product-card__price">{t.products.price(product.price)}</span>
                <a
                  class="btn btn--ghost product-card__reserve"
                  href={reserveHref(product.name)}
                  data-reserve={formEnabled ? product.name : undefined}
                >
                  {t.products.reserve}
                  <span class="visually-hidden">{t.products.reserveHidden(product.name)}</span>
                </a>
              </div>
            </div>
          </li>
        ))
      }
    </ul>

    <p class="product-note">
      {t.products.noteBefore}
      <a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>{t.products.noteAfter}
    </p>

    {
      formEnabled && (
        <dialog class="reserve" id="reserve-dialog" aria-labelledby="reserve-tittel">
          <div class="reserve__inner" data-reserve-body>
            <div class="reserve__head">
              <h3 id="reserve-tittel">{t.reserve.dialogTitle}</h3>
              <button
                type="button"
                class="reserve__close"
                data-reserve-close
                aria-label={t.reserve.close}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </div>
            <p class="reserve__product">
              {t.reserve.productLabel}: <strong data-reserve-product-name />
            </p>
            <form class="reserve__form" data-reserve-form>
              <input type="hidden" name="product" data-reserve-product-input />
              <div class="reserve__field">
                <label for="res-navn">{t.reserve.name}</label>
                <input
                  id="res-navn"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  maxlength="80"
                />
              </div>
              <div class="reserve__field">
                <label for="res-tlf">{t.reserve.phone}</label>
                <input
                  id="res-tlf"
                  name="phone"
                  type="tel"
                  required
                  autocomplete="tel"
                  maxlength="20"
                />
              </div>
              <div class="reserve__field">
                <label for="res-epost">
                  {t.reserve.email} <span class="reserve__opt">({t.reserve.optional})</span>
                </label>
                <input
                  id="res-epost"
                  name="email"
                  type="email"
                  autocomplete="email"
                  maxlength="120"
                />
              </div>
              <div class="reserve__field">
                <label for="res-naar">{t.reserve.when}</label>
                <select id="res-naar" name="when">
                  <option value="">{t.reserve.whenAsap}</option>
                  {pickupDays.map((day) => (
                    <option value={t.days[day] ?? day}>{t.days[day] ?? day}</option>
                  ))}
                </select>
              </div>
              <div class="reserve__field">
                <label for="res-melding">
                  {t.reserve.message} <span class="reserve__opt">({t.reserve.optional})</span>
                </label>
                <textarea id="res-melding" name="message" rows="3" maxlength="500" />
              </div>
              <div class="reserve__hp" aria-hidden="true">
                <label for="res-web">Nettside</label>
                <input
                  id="res-web"
                  name="website"
                  type="text"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>
              <p class="reserve__privacy">
                {t.reserve.privacyNote}{" "}
                <a href={privacyHref}>{t.privacy.footerLink}</a>
              </p>
              <p
                class="reserve__status"
                role="status"
                data-reserve-status
                data-sending={t.reserve.sending}
                data-error-title={t.reserve.errorTitle}
                data-error-body={t.reserve.errorBody}
                data-error-sms={t.reserve.errorSmsLink}
              />
              <div class="reserve__actions">
                <button class="btn btn--primary" type="submit" data-reserve-submit>
                  {t.reserve.submit}
                </button>
                <button class="btn btn--ghost" type="button" data-reserve-close>
                  {t.reserve.cancel}
                </button>
              </div>
            </form>
          </div>
          <div class="reserve__inner reserve__success" data-reserve-success hidden>
            <div class="reserve__head">
              <h3>{t.reserve.successTitle}</h3>
              <button
                type="button"
                class="reserve__close"
                data-reserve-close
                aria-label={t.reserve.close}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
              </button>
            </div>
            <p>{t.reserve.successBody}</p>
            <div class="reserve__actions">
              <button class="btn btn--primary" type="button" data-reserve-close>
                {t.reserve.close}
              </button>
            </div>
          </div>
        </dialog>
      )
    }
  </div>
</section>

<style>
  .product-grid {
    list-style: none;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .product-card__media {
    position: relative;
  }
  .product-card__media :global(.ph) {
    border-radius: 0;
  }
  .product-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-on-gold);
    background: var(--color-gold);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
  }
  .product-card__body {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    flex: 1;
  }
  .product-card__cat {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-sage);
  }
  .product-card h3 {
    margin: 0.35rem 0 0.1rem;
  }
  .product-card__brand {
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    margin: 0 0 0.6rem;
  }
  .product-card__desc {
    font-size: 0.98rem;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .product-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
  }
  .product-card__price {
    font-size: 1.15rem;
    font-weight: 600;
  }
  /* Hele kortet klikkbart (Heydon Pickering-mønster): «Reserver» er én lenke
     som strekkes over kortet, så både bilde og tekst fører til reservasjon. */
  .product-card__reserve::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }
  .product-card:hover {
    border-color: var(--color-bronze);
    box-shadow: 0 14px 32px -20px rgba(0, 0, 0, 0.5);
    transform: translateY(-2px);
  }
  .product-card:focus-within {
    box-shadow: 0 0 0 3px var(--color-focus);
  }
  @media (prefers-reduced-motion: reduce) {
    .product-card {
      transition: none;
    }
    .product-card:hover {
      transform: none;
    }
  }
  .product-note {
    margin-top: 1.75rem;
    color: var(--color-ink-soft);
  }

  /* --- Reservasjonsdialog ------------------------------------------------ */
  .reserve {
    width: min(92vw, 27rem);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-white);
    color: var(--color-ink);
    padding: 0;
    box-shadow: var(--shadow-md);
  }
  .reserve::backdrop {
    background: rgba(38, 33, 28, 0.55);
  }
  .reserve__inner {
    padding: 1.5rem;
  }
  .reserve__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .reserve__head h3 {
    margin: 0;
  }
  .reserve__close {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: none;
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-radius: 50%;
    color: var(--color-ink);
    cursor: pointer;
  }
  .reserve__close svg {
    width: 1.1rem;
    height: 1.1rem;
  }
  .reserve__product {
    margin: 0 0 1rem;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
  }
  .reserve__form {
    display: grid;
    gap: 0.85rem;
  }
  .reserve__field {
    display: grid;
    gap: 0.3rem;
  }
  .reserve__field label {
    font-size: 0.88rem;
    font-weight: 600;
  }
  .reserve__opt {
    font-weight: 400;
    color: var(--color-ink-soft);
  }
  .reserve__field input,
  .reserve__field select,
  .reserve__field textarea {
    font: inherit;
    color: inherit;
    background: var(--color-cream);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 0.6rem 0.75rem;
    width: 100%;
  }
  .reserve__field textarea {
    resize: vertical;
  }
  /* Honningkrukke: usynlig for mennesker, fristende for roboter. */
  .reserve__hp {
    position: absolute !important;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  .reserve__privacy {
    font-size: 0.82rem;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .reserve__privacy a {
    color: var(--color-accent-dark);
  }
  .reserve__status {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    min-height: 1.2em;
  }
  .reserve__status a {
    color: var(--color-accent-dark);
  }
  .reserve__status.is-error {
    color: #8a2f22;
  }
  .reserve__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.25rem;
  }

  @media (min-width: 40rem) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

<script>
  // Progressiv forbedring: uten JavaScript (eller uten e-postoppsett) er
  // «Reserver» en vanlig SMS-lenke. Med JavaScript åpner vi skjemaet og
  // faller tilbake til SMS-lenken hvis innsendingen feiler.
  const dialog = document.querySelector<HTMLDialogElement>("#reserve-dialog");

  if (dialog && typeof dialog.showModal === "function") {
    const body = dialog.querySelector<HTMLElement>("[data-reserve-body]");
    const success = dialog.querySelector<HTMLElement>("[data-reserve-success]");
    const form = dialog.querySelector<HTMLFormElement>("[data-reserve-form]");
    const nameEl = dialog.querySelector<HTMLElement>("[data-reserve-product-name]");
    const productInput = dialog.querySelector<HTMLInputElement>(
      "[data-reserve-product-input]",
    );
    const status = dialog.querySelector<HTMLElement>("[data-reserve-status]");
    const submitBtn = dialog.querySelector<HTMLButtonElement>(
      "[data-reserve-submit]",
    );
    let smsFallback = "";

    const resetViews = () => {
      if (body) body.hidden = false;
      if (success) success.hidden = true;
      if (status) {
        status.textContent = "";
        status.classList.remove("is-error");
      }
      if (submitBtn) submitBtn.disabled = false;
    };

    document
      .querySelectorAll<HTMLAnchorElement>("[data-reserve]")
      .forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const product = link.dataset.reserve ?? "";
          smsFallback = link.href;
          if (nameEl) nameEl.textContent = product;
          if (productInput) productInput.value = product;
          form?.reset();
          resetViews();
          dialog.showModal();
          dialog.querySelector<HTMLInputElement>("#res-navn")?.focus();
        });
      });

    dialog.querySelectorAll("[data-reserve-close]").forEach((btn) =>
      btn.addEventListener("click", () => dialog.close()),
    );
    // Klikk på selve bakteppet lukker (klikk inni treffer .reserve__inner).
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      const data = Object.fromEntries(new FormData(form).entries());
      if (submitBtn) submitBtn.disabled = true;
      if (status) {
        status.classList.remove("is-error");
        status.textContent = status.dataset.sending ?? "…";
      }
      try {
        const res = await fetch("/api/reserve", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(String(res.status));
        if (body) body.hidden = true;
        if (success) {
          success.hidden = false;
          success.querySelector<HTMLButtonElement>("[data-reserve-close]")?.focus();
        }
      } catch {
        if (status) {
          status.classList.add("is-error");
          status.innerHTML = "";
          status.append(
            document.createTextNode(`${status.dataset.errorTitle ?? ""} ${status.dataset.errorBody ?? ""} `),
          );
          const a = document.createElement("a");
          a.href = smsFallback;
          a.textContent = status.dataset.errorSms ?? "SMS";
          status.append(a, document.createTextNode("."));
        }
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>
