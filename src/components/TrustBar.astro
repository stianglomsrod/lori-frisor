---
import { getSettings } from "@lib/content";

const { contact } = await getSettings();

const items = [
  { label: "Adresse", value: `${contact.addressStreet}, ${contact.addressCity}`, href: contact.mapsUrl, icon: "pin" },
  { label: "Ring oss", value: contact.phoneDisplay, href: `tel:${contact.phone}`, icon: "phone" },
  { label: "Drop-in & timer", value: "Man–fre", href: "#kontakt", icon: "clock" },
];
---

<section class="trust" aria-label="Praktisk informasjon">
  <div class="container trust__grid reveal">
    {
      items.map((item) => (
        <a class="trust__item" href={item.href}>
          <span class="trust__icon" aria-hidden="true">
            {item.icon === "pin" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            )}
            {item.icon === "phone" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.5 2.8.6a2 2 0 0 1 1.7 2Z"/></svg>
            )}
            {item.icon === "clock" && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            )}
          </span>
          <span class="trust__text">
            <span class="trust__label">{item.label}</span>
            <span class="trust__value">{item.value}</span>
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .trust {
    border-block: 1px solid var(--color-line);
    background: var(--color-white);
  }
  .trust__grid {
    display: grid;
    gap: 0.5rem;
    padding-block: 1rem;
  }
  .trust__item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.5rem;
    text-decoration: none;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
  }
  .trust__item:hover {
    background: var(--color-sand);
  }
  .trust__icon {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex: none;
    color: var(--color-accent-dark);
    background: var(--color-sand);
    border-radius: 50%;
  }
  .trust__icon svg {
    width: 1.3rem;
    height: 1.3rem;
  }
  .trust__text {
    display: flex;
    flex-direction: column;
  }
  .trust__label {
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .trust__value {
    font-weight: 600;
  }

  @media (min-width: 48rem) {
    .trust__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }
</style>
