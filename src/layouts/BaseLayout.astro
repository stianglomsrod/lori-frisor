---
import "../styles/global.css";
import ConsentBanner from "@components/ConsentBanner.astro";
import { getSettings, getOpeningHours, getServices } from "@lib/content";
import {
  resolveLocale,
  htmlLang,
  ogLocale,
  locales,
  localeHome,
} from "@i18n/config";
import { useTranslations } from "@i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const t = useTranslations(locale);
const { site, contact, social } = await getSettings();
const openingHours = await getOpeningHours();
const services = await getServices(locale);

interface Props {
  title?: string;
  description?: string;
  /** Sett false på undersider (personvern, 404) som ikke skal indeks-prioriteres. */
  withJsonLd?: boolean;
}

const {
  title = `${site.name} – ${t.seo.tagline}`,
  description = t.seo.description,
  withJsonLd = true,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImage = new URL("/og.jpg", Astro.site ?? site.url).href;
// hreflang-alternativer for søkemotorer (én URL per språk).
const alternates = locales.map((loc) => ({
  hreflang: htmlLang[loc],
  ogLocale: ogLocale[loc],
  href: new URL(localeHome(loc), Astro.site ?? site.url).href,
}));
const defaultHref = alternates[0].href;

// --- Strukturert data (LocalBusiness) – styrker lokal synlighet i søk. ---
// schema.org-krav: engelske dagkoder (Mo–Su) og bindestrek i tidsrom.
const dayCode: Record<string, string> = {
  Mandag: "Mo",
  Tirsdag: "Tu",
  Onsdag: "We",
  Torsdag: "Th",
  Fredag: "Fr",
  Lørdag: "Sa",
  Søndag: "Su",
};
// Normaliser eier-skrevne tider («09.00–16.00» → «09:00-16:00»); ugyldige
// verdier utelates fra strukturert data i stedet for å forurense den.
const normalizeHours = (value: string): string | null => {
  const v = value.replace(/\./g, ":").replace(/[–—]/g, "-").replace(/\s+/g, "");
  return /^\d{1,2}:\d{2}-\d{1,2}:\d{2}$/.test(v) ? v : null;
};
const schemaOpeningHours = openingHours
  .filter((d) => !d.closed)
  .map((d) => {
    const code = dayCode[d.day];
    const hours = normalizeHours(d.hours);
    return code && hours ? `${code} ${hours}` : null;
  })
  .filter((v): v is string => v !== null);

const prices = services
  .map((s) => s.priceFrom)
  .filter((p): p is number => p !== null);
const priceRange =
  prices.length > 0
    ? `kr ${Math.min(...prices)}–${Math.max(...prices)}`
    : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  "@id": `${site.url}/#salong`,
  name: site.name,
  description: t.seo.description,
  url: site.url,
  image: ogImage,
  telephone: `+47${contact.phone}`,
  email: contact.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: contact.addressStreet,
    postalCode: contact.addressZip,
    addressLocality: contact.addressCity,
    addressCountry: "NO",
  },
  hasMap: contact.mapsUrl,
  sameAs: social.map((s) => s.url),
  openingHours: schemaOpeningHours,
  ...(priceRange ? { priceRange } : {}),
};
// «</script>» i CMS-innhold skal aldri kunne bryte ut av script-taggen.
const jsonLdSafe = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Markér at JS er aktivt før paint, så scroll-avsløring ikke gir glimt -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={defaultHref} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#faf7f1" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1b1815" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph / deling (Facebook, Instagram, meldingsapper) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} – ${t.seo.tagline}`} />
    <meta property="og:locale" content={ogLocale[locale]} />
    {
      alternates
        .filter((alt) => alt.ogLocale !== ogLocale[locale])
        .map((alt) => (
          <meta property="og:locale:alternate" content={alt.ogLocale} />
        ))
    }
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter/X-delingskort -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Skrifter: lastes med swap og degraderer pent til system-skrift -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap"
    />

    {
      withJsonLd && (
        <script type="application/ld+json" is:inline set:html={jsonLdSafe} />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#hovedinnhold">{t.skipLink}</a>
    <slot />
    <ConsentBanner />

    <script>
      // Diskré scroll-avsløring: legg til .is-visible når elementet kommer i syne.
      const items = document.querySelectorAll<HTMLElement>(".reveal");
      if (items.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
        );
        items.forEach((el) => io.observe(el));
      } else {
        items.forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>
