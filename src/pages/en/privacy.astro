---
/**
 * Privacy policy (English). Norwegian version: src/pages/personvern.astro.
 * Keep the two in sync when the processing changes.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { getSettings } from "@lib/content";
import { localePrivacy } from "@i18n/config";

const { site, contact } = await getSettings();
const orgNr = "926 980 343"; // LORI-FRISØR AS (Norwegian Register of Business Enterprises)
const updated = "4 July 2026";
---

<BaseLayout
  title={`Privacy policy – ${site.name}`}
  description={`How ${site.name} handles personal data on ${site.url.replace("https://", "")}.`}
  withJsonLd={false}
>
  <Header langPaths={localePrivacy} />
  <main id="hovedinnhold">
    <section class="section">
      <div class="container privacy">
        <p class="eyebrow">Privacy</p>
        <h1>Privacy policy</h1>
        <p class="privacy__lead">
          This page explains what happens to personal data when you use the
          {site.name} website. In short: the site has no login, no analytics
          and no marketing tracking.
        </p>

        <h2>Who is responsible</h2>
        <p>
          LORI-FRISØR AS (org. no. {orgNr}), {contact.addressStreet},
          {contact.addressZip} {contact.addressCity}, Norway, is the data
          controller for the processing described here. Questions can be sent
          to <a href={`mailto:${contact.email}`}>{contact.email}</a> or raised
          by phone on <a href={`tel:${contact.phone}`}>{contact.phoneDisplay}</a>.
        </p>

        <h2>What we process – and why</h2>

        <h3>Visiting the website</h3>
        <p>
          The site is hosted by Vercel. Like all websites, the server keeps
          technical logs (including IP address and time of access) for
          operations and security. The legal basis is our legitimate interest
          in running and securing the site. The logs are kept briefly by the
          provider and are not used for anything else.
        </p>

        <h3>Fonts</h3>
        <p>
          The fonts on this site are served by Google Fonts. When your browser
          loads a font, Google sees your IP address. We use no other Google
          services without consent, and the fonts set no cookies. The legal
          basis is our legitimate interest in a fast, readable site.
        </p>

        <h3>Map</h3>
        <p>
          The map in the contact section comes from Google Maps, but is only
          loaded <strong>after you say yes</strong> – either in the cookie
          banner or by pressing “Show map”. Google may then set its own
          cookies and see your IP address. The legal basis is consent, and you
          can change your mind at any time via “Manage cookies” at the bottom
          of the page.
        </p>

        <h3>Product reservations</h3>
        <p>
          If you reserve a product through the form, we send your name, phone
          number and any email address and message as an email to the salon so
          the product can be set aside for you. The legal basis is that the
          processing is necessary to handle your request. The details are used
          for nothing else and are deleted once the reservation is dealt with.
          If you choose SMS or phone instead, that goes through your own app –
          the website stores nothing.
        </p>

        <h3>Booking appointments</h3>
        <p>
          Appointments are booked with Timma (bestill.timma.no), a separate
          service with its own data controller and its own privacy policy. Our
          site simply sends you there – no data about you travels along.
        </p>

        <h2>Cookies and local storage</h2>
        <div class="privacy__tablewrap">
          <table class="privacy__table">
            <caption class="visually-hidden">
              Overview of cookies and local storage
            </caption>
            <thead>
              <tr>
                <th scope="col">Name</th>
                <th scope="col">Type</th>
                <th scope="col">Purpose</th>
                <th scope="col">Duration</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">lori-consent-v1</th>
                <td>Local storage (first party)</td>
                <td>Remembers your cookie choice. Strictly necessary.</td>
                <td>Until you clear browser data</td>
              </tr>
              <tr>
                <th scope="row">Google Maps cookies</th>
                <td>Third party (Google)</td>
                <td>Set by Google once you have chosen to show the map.</td>
                <td>Controlled by Google</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          No non-essential cookies are set before you make an active choice,
          and “Necessary only” is exactly as easy as “Accept all”.
        </p>

        <h2>Who we share with</h2>
        <ul class="privacy__list" role="list">
          <li><strong>Vercel Inc.</strong> (USA) – website hosting.</li>
          <li><strong>Google</strong> (USA) – fonts, and the map if you consent.</li>
          <li><strong>Brevo</strong> (EU/France) – delivery of reservation emails to the salon.</li>
        </ul>
        <p>
          Transfers to providers in the USA rely on the EU Commission's
          Standard Contractual Clauses (SCC) and/or the EU-U.S. Data Privacy
          Framework. We never sell data and share nothing beyond what is
          listed here.
        </p>

        <h2>Your rights</h2>
        <p>
          You have the right to access, rectification, erasure, restriction
          and objection, and to withdraw consent. Contact us at{" "}
          <a href={`mailto:${contact.email}`}>{contact.email}</a> and we will
          help. You can also complain to the Norwegian Data Protection
          Authority,{" "}
          <a href="https://www.datatilsynet.no" target="_blank" rel="noopener"
            >Datatilsynet<span class="visually-hidden">&nbsp;(opens in a new tab)</span></a
          >, if you believe the processing is unlawful.
        </p>

        <h2>Changes</h2>
        <p>
          If we make significant changes to what is processed, we update this
          page first. Last updated: {updated}.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .privacy {
    max-width: 46rem;
  }
  .privacy h1 {
    margin-bottom: 0.75rem;
  }
  .privacy__lead {
    font-size: 1.15rem;
    color: var(--color-ink-soft);
    margin-bottom: 2rem;
  }
  .privacy h2 {
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    margin-top: 2.25rem;
  }
  .privacy h3 {
    margin-top: 1.5rem;
  }
  .privacy__tablewrap {
    overflow-x: auto;
    margin: 1rem 0;
  }
  .privacy__table {
    width: 100%;
    min-width: 34rem;
    border-collapse: collapse;
    font-size: 0.95rem;
    background: var(--color-white);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
  }
  .privacy__table th,
  .privacy__table td {
    text-align: left;
    padding: 0.7rem 0.85rem;
    border-bottom: 1px solid var(--color-line);
    vertical-align: top;
  }
  .privacy__table thead th {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .privacy__table tbody tr:last-child th,
  .privacy__table tbody tr:last-child td {
    border-bottom: 0;
  }
  .privacy__list {
    list-style: none;
    display: grid;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }
</style>
